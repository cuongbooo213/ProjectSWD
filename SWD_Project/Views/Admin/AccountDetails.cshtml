@model SWD_Project.Models.Entities.User

@{
    ViewData["Title"] = "Account Details";
    var cv = ViewBag.CV as SWD_Project.Models.Entities.MentorCV;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Account Details</h1>
    <a asp-action="ListAccounts" class="btn btn-outline-secondary">← Back to List</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<div class="row g-4">
    <!-- Account Info -->
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-header bg-dark text-white"><strong>Account Information</strong></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">ID</dt>
                    <dd class="col-sm-8">@Model.Id</dd>
                    <dt class="col-sm-4">Username</dt>
                    <dd class="col-sm-8">@Model.Username</dd>
                    <dt class="col-sm-4">Full Name</dt>
                    <dd class="col-sm-8">@Model.FullName</dd>
                    <dt class="col-sm-4">Email</dt>
                    <dd class="col-sm-8">@Model.Email</dd>
                    <dt class="col-sm-4">Role</dt>
                    <dd class="col-sm-8"><span class="badge bg-primary">@Model.Role</span></dd>
                    <dt class="col-sm-4">Status</dt>
                    <dd class="col-sm-8">
                        @if (Model.IsBlocked)
                        {
                            <span class="badge bg-danger">Blocked</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Active</span>
                        }
                    </dd>
                </dl>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="col-md-6">
        <!-- Block / Unblock -->
        <div class="card mb-3">
            <div class="card-header bg-warning text-dark"><strong>Block / Unblock Account</strong></div>
            <div class="card-body">
                <form asp-action="BlockAccount" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    @if (Model.IsBlocked)
                    {
                        <p class="text-muted">Click to unblock this account.</p>
                        <input type="hidden" name="block" value="false" />
                        <button type="submit" class="btn btn-success">Unblock Account</button>
                    }
                    else
                    {
                        <p class="text-muted">Click to block this account from logging in.</p>
                        <input type="hidden" name="block" value="true" />
                        <button type="submit" class="btn btn-danger">Block Account</button>
                    }
                </form>
            </div>
        </div>

        <!-- Reset Password -->
        <div class="card">
            <div class="card-header bg-secondary text-white"><strong>Reset Password</strong></div>
            <div class="card-body">
                <form asp-action="ResetPassword" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="mb-3">
                        <label class="form-label">New Password</label>
                        <input type="password" name="newPassword" class="form-control" placeholder="Min 6 characters" required />
                    </div>
                    <button type="submit" class="btn btn-secondary">Reset Password</button>
                </form>
            </div>
        </div>
    </div>

    <!-- CV Info (Mentor only) -->
    @if (cv != null)
    {
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-primary text-white"><strong>Mentor CV</strong></div>
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">Bio</dt>
                        <dd class="col-sm-9">@cv.Bio</dd>
                        <dt class="col-sm-3">Experience</dt>
                        <dd class="col-sm-9">@cv.ExperienceYears years</dd>
                        <dt class="col-sm-3">Skills</dt>
                        <dd class="col-sm-9">
                            @foreach (var s in cv.Skills ?? new List<SWD_Project.Models.Entities.Skill>())
                            {
                                <span class="badge bg-secondary me-1">@s.Name</span>
                            }
                        </dd>
                        <dt class="col-sm-3">CV Status</dt>
                        <dd class="col-sm-9">
                            <span class="badge @(cv.IsApproved ? "bg-success" : "bg-warning text-dark")">
                                @(cv.IsApproved ? "Approved" : "Pending")
                            </span>
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
    }

    <!-- Request Stats -->
    @if (Model.Requests != null && Model.Requests.Any())
    {
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-info text-white"><strong>Requests (@Model.Requests.Count total)</strong></div>
                <div class="card-body">
                    <p>Pending: @Model.Requests.Count(r => r.Status == SWD_Project.Models.Enums.RequestStatus.Pending)</p>
                    <p>Accepted: @Model.Requests.Count(r => r.Status == SWD_Project.Models.Enums.RequestStatus.Accepted)</p>
                    <p>Completed: @Model.Requests.Count(r => r.Status == SWD_Project.Models.Enums.RequestStatus.Completed)</p>
                </div>
            </div>
        </div>
    }
</div>
