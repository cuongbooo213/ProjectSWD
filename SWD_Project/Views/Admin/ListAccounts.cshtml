@model IEnumerable<SWD_Project.Models.Entities.User>

@{
    ViewData["Title"] = "Manage Accounts";
}

<h1 class="mb-4">Manage Accounts</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<form method="get" asp-action="ListAccounts" class="row g-2 mb-4">
    <div class="col-md-5">
        <input type="text" name="search" value="@ViewBag.Search" class="form-control" placeholder="Search by name, username, email..." />
    </div>
    <div class="col-md-3">
        <select name="role" class="form-select">
            <option value="">-- All Roles --</option>
            @foreach (var r in Enum.GetValues<SWD_Project.Models.Enums.Role>())
            {
                <option value="@r" selected="@(ViewBag.Role == r.ToString())">@r</option>
            }
        </select>
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Filter</button>
        <a asp-action="ListAccounts" class="btn btn-outline-secondary ms-1">Reset</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>#</th>
                <th>Username</th>
                <th>Full Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Id</td>
                    <td class="fw-bold">@user.Username</td>
                    <td>@user.FullName</td>
                    <td>@user.Email</td>
                    <td>
                        @{
                            var badgeColor = user.Role.ToString() switch
                            {
                                "Admin" => "bg-danger",
                                "Mentor" => "bg-primary",
                                _ => "bg-secondary"
                            };
                        }
                        <span class="badge @badgeColor">@user.Role</span>
                    </td>
                    <td>
                        @if (user.IsBlocked)
                        {
                            <span class="badge bg-danger">Blocked</span>
                        }
                        else
                        {
                            <span class="badge bg-success">Active</span>
                        }
                    </td>
                    <td>
                        <a asp-action="AccountDetails" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary">Details</a>
                    </td>
                </tr>
            }
            @if (!Model.Any())
            {
                <tr><td colspan="7" class="text-center text-muted py-4">No accounts found.</td></tr>
            }
        </tbody>
    </table>
</div>
