@model SWD_Project.Models.Entities.MentorCV

@{
    ViewData["Title"] = "My CV";
    var allSkills = ViewBag.AllSkills as List<SWD_Project.Models.Entities.Skill>;
}

<h1>My CV</h1>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success mt-3">@TempData["Success"]</div>
}

<div class="card mt-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">CV Details</h5>
    </div>
    <div class="card-body">
        @if (Model.Id > 0)
        {
            <div class="alert @(Model.IsApproved ? "alert-success" : "alert-warning")">
                <strong>Status:</strong> @(Model.IsApproved ? "Approved and Visible to Mentees" : "Pending Admin Approval")
            </div>
        }
        
        <form asp-action="MyCV" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="MentorId" />

            <div class="mb-3">
                <label asp-for="Bio" class="form-label fw-bold">Bio</label>
                <textarea asp-for="Bio" class="form-control" rows="4" placeholder="Tell mentees about yourself..." required></textarea>
                <span asp-validation-for="Bio" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ExperienceYears" class="form-label fw-bold">Years of Experience</label>
                <input asp-for="ExperienceYears" class="form-control" type="number" min="0" required />
                <span asp-validation-for="ExperienceYears" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label class="form-label fw-bold d-block">Skills/Expertise</label>
                <div class="row">
                    @if (allSkills != null)
                    {
                        foreach (var skill in allSkills)
                        {
                            var isChecked = Model.Skills != null && Model.Skills.Any(s => s.Id == skill.Id);
                            <div class="col-md-4 mb-2">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="selectedSkills" value="@skill.Id" id="skill_@skill.Id" @(isChecked ? "checked" : "")>
                                    <label class="form-check-label" for="skill_@skill.Id">
                                        @skill.Name
                                    </label>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

            <button type="submit" class="btn btn-primary">Save CV</button>
        </form>
    </div>
</div>
