@using SWD_Project.Models.Enums
@{
    ViewData["Title"] = "Register";
}

<style>
    body {
        background-color: #f4f7f6;
    }

    .auth-bg {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem 0;
    }

    .auth-card {
        border-radius: 1rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        overflow: hidden;
    }

    .auth-image {
        background-image: url('https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=1471&auto=format&fit=crop');
        background-size: cover;
        background-position: center;
    }

    .auth-form-wrapper {
        padding: 3rem;
        background-color: white;
    }

    .btn-brand {
        background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        color: white;
        border: none;
        transition: all 0.3s ease;
    }

        .btn-brand:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(56, 239, 125, 0.4);
            color: white;
        }
</style>

<div class="auth-bg">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-10 col-lg-12 col-md-9">
                <div class="card auth-card border-0">
                    <div class="row g-0 flex-row-reverse">
                        <div class="col-lg-5 d-none d-lg-block auth-image"></div>
                        <div class="col-lg-7 auth-form-wrapper">
                            <div class="text-center mb-4">
                                <h2 class="fw-bold text-gray-900 mb-2">Join HappyProgramming</h2>
                                <p class="text-muted">Create a new account today!</p>
                            </div>

                            <form action="/Auth/Register" method="post">
                                @Html.AntiForgeryToken()

                                @if (!ViewData.ModelState.IsValid)
                                {
                                    <div class="text-danger small mb-3 ms-2">
                                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                        {
                                            <div>@error.ErrorMessage</div>
                                        }
                                    </div>
                                }

                                <div class="row g-3 mb-3">
                                    <div class="col-md-6">
                                        <div class="form-floating">
                                            <input name="username" class="form-control rounded-pill px-4"
                                                   placeholder="Enter username"
                                                   value="@(Context.Request.HasFormContentType? Context.Request.Form["username"].ToString() : "")" />
                                            <label class="ms-2">Username</label>
                                            @if (ViewData.ModelState["Username"]?.Errors.Count > 0)
                                            {
                                                <span class="text-danger small ms-3">@ViewData.ModelState["Username"].Errors[0].ErrorMessage</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-floating">
                                            <input name="fullName" class="form-control rounded-pill px-4"
                                                   placeholder="Enter your full name"
                                                   value="@(Context.Request.HasFormContentType? Context.Request.Form["fullName"].ToString() : "")" />
                                            <label class="ms-2">Full Name</label>
                                            @if (ViewData.ModelState["FullName"]?.Errors.Count > 0)
                                            {
                                                <span class="text-danger small ms-3">@ViewData.ModelState["FullName"].Errors[0].ErrorMessage</span>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <div class="form-floating mb-3">
                                    <input name="email" class="form-control rounded-pill px-4" type="email"
                                           placeholder="name@example.com"
                                           value="@(Context.Request.HasFormContentType? Context.Request.Form["email"].ToString() : "")" />
                                    <label class="ms-2">Email address</label>
                                    @if (ViewData.ModelState["Email"]?.Errors.Count > 0)
                                    {
                                        <span class="text-danger small ms-3">@ViewData.ModelState["Email"].Errors[0].ErrorMessage</span>
                                    }
                                </div>

                                <div class="mb-3 px-3">
                                    <label class="form-label ms-1 fw-bold text-muted">Register As</label>
                                    <div class="d-flex flex-column flex-sm-row gap-2 gap-sm-4 ms-2">
                                        <div class="form-check">
                                            <input class="form-check-input border-secondary" type="radio"
                                                   name="role" value="@((int)Role.Mentee)" checked />
                                            <label class="form-check-label">
                                                Mentee <small class="text-muted d-block">Learn specific skills</small>
                                            </label>
                                        </div>
                                        <div class="form-check">
                                            <input class="form-check-input border-secondary" type="radio"
                                                   name="role" value="@((int)Role.Mentor)" />
                                            <label class="form-check-label">
                                                Mentor <small class="text-muted d-block">Teach and share knowledge</small>
                                            </label>
                                        </div>
                                    </div>
                                    @if (ViewData.ModelState["Role"]?.Errors.Count > 0)
                                    {
                                        <span class="text-danger small ms-3">@ViewData.ModelState["Role"].Errors[0].ErrorMessage</span>
                                    }
                                </div>

                                <div class="row g-3 mb-4">
                                    <div class="col-md-6">
                                        <div class="form-floating">
                                            <input name="password" class="form-control rounded-pill px-4"
                                                   type="password" placeholder="Create a password" />
                                            <label class="ms-2">Password</label>
                                            @if (ViewData.ModelState["Password"]?.Errors.Count > 0)
                                            {
                                                <span class="text-danger small ms-3">@ViewData.ModelState["Password"].Errors[0].ErrorMessage</span>
                                            }
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-floating">
                                            <input name="confirmPassword" class="form-control rounded-pill px-4"
                                                   type="password" placeholder="Confirm password" />
                                            <label class="ms-2">Confirm Password</label>
                                            @if (ViewData.ModelState["ConfirmPassword"]?.Errors.Count > 0)
                                            {
                                                <span class="text-danger small ms-3">@ViewData.ModelState["ConfirmPassword"].Errors[0].ErrorMessage</span>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <div class="d-grid gap-2 mb-4">
                                    <button type="submit" class="btn btn-brand btn-lg rounded-pill fw-bold">Register Account</button>
                                </div>
                            </form>

                            <hr>
                            <div class="text-center mt-4">
                                <span class="text-muted">Already have an account?</span>
                                <a href="/Auth/Login" class="text-decoration-none fw-bold text-success ms-1">Login here!</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>