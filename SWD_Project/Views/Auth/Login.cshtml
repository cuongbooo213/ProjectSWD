@model SWD_Project.Models.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = "_Layout"; // Or omit if using global layout
}

<style>
    body {
        background-color: #f4f7f6;
    }
    .auth-bg {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .auth-card {
        border-radius: 1rem;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        overflow: hidden;
    }
    .auth-image {
        background-image: url('https://images.unsplash.com/photo-1517048676732-d65bc937f952?q=80&w=1470&auto=format&fit=crop');
        background-size: cover;
        background-position: center;
    }
    .auth-form-wrapper {
        padding: 3rem;
        background-color: white;
    }
    .btn-brand {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        border: none;
        transition: all 0.3s ease;
    }
    .btn-brand:hover {
        transform: translateY(-2px);
        box-shadow: 0 5px 15px rgba(118, 75, 162, 0.4);
        color: white;
    }
</style>

<div class="auth-bg py-5">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-10 col-lg-12 col-md-9">
                <div class="card auth-card border-0">
                    <div class="row g-0">
                        <div class="col-lg-6 d-none d-lg-block auth-image"></div>
                        <div class="col-lg-6 auth-form-wrapper">
                            <div class="text-center mb-4">
                                <h2 class="fw-bold text-gray-900 mb-2">Welcome Back!</h2>
                                <p class="text-muted">Sign in to continue to HappyProgramming</p>
                            </div>

                            @if (TempData["SuccessMessage"] != null)
                            {
                                <div class="alert alert-success alert-dismissible fade show" role="alert">
                                    <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                            }

                            <form asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]" method="post" class="user">
                                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                                <div class="form-floating mb-3">
                                    <input asp-for="Username" class="form-control rounded-pill px-4" id="inputUsername" placeholder="Enter username" />
                                    <label asp-for="Username" for="inputUsername" class="ms-2">Username</label>
                                    <span asp-validation-for="Username" class="text-danger small ms-3"></span>
                                </div>

                                <div class="form-floating mb-4">
                                    <input asp-for="Password" class="form-control rounded-pill px-4" id="inputPassword" type="password" placeholder="Enter password" />
                                    <label asp-for="Password" for="inputPassword" class="ms-2">Password</label>
                                    <span asp-validation-for="Password" class="text-danger small ms-3"></span>
                                </div>

                                <div class="d-grid gap-2 mb-4">
                                    <button type="submit" class="btn btn-brand btn-lg rounded-pill fw-bold">Login</button>
                                </div>
                            </form>

                            <hr>
                            
                            <div class="text-center mt-4">
                                <span class="text-muted">Don't have an account?</span>
                                <a asp-action="Register" class="text-decoration-none fw-bold text-primary ms-1">Create an Account!</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
