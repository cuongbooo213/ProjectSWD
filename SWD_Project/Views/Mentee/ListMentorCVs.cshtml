@using SWD_Project.Models.Entities
@model IEnumerable<MentorCV>

@{
    ViewData["Title"] = "Danh sách Mentor CV";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Danh sách Mentor CV</h2>
        <a asp-controller="Request" asp-action="Index" class="btn btn-secondary">Quay về danh sách Yêu cầu</a>
    </div>
    
    <hr />

    <!-- Filter Form -->
    <div class="card mb-4 border-0 shadow-sm" style="border-radius: 12px; background-color: #f8f9fa;">
        <div class="card-body">
            <form asp-action="ListMentorCVs" method="get" class="row g-3 align-items-end">
                <div class="col-md-4">
                    <label for="categoryId" class="form-label fw-bold">Danh mục kỹ năng</label>
                    <select name="categoryId" id="categoryId" class="form-select" onchange="this.form.submit()">
                        <option value="">-- Tất cả danh mục --</option>
                        @foreach (var cat in ViewBag.Categories)
                        {
                            <option value="@cat.Id" selected="@(ViewBag.SelectedCategory == cat.Id ? "selected" : null)">@cat.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <label for="skillId" class="form-label fw-bold">Kỹ năng cụ thể</label>
                    <select name="skillId" id="skillId" class="form-select" onchange="this.form.submit()">
                        <option value="">-- Tất cả kỹ năng --</option>
                        @foreach (var skill in ViewBag.Skills)
                        {
                            <option value="@skill.Id" selected="@(ViewBag.SelectedSkill == skill.Id ? "selected" : null)">@skill.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-4">
                    <button type="submit" class="btn btn-primary px-4"><i class="bi bi-search"></i> Lọc danh sách</button>
                    <a asp-action="ListMentorCVs" class="btn btn-outline-secondary ms-2">Xóa bộ lọc</a>
                </div>
            </form>
        </div>
    </div>
    <!-- End Filter Form -->

    <div class="row">
        @if (Model != null && Model.Any())
        {
            @foreach (var cv in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm h-100 border-0" style="border-radius: 12px; transition: transform 0.2s;">
                        <div class="card-body">
                            <h4 class="card-title text-primary fw-bold">@cv.Mentor.FullName</h4>
                            <h6 class="card-subtitle mb-3 text-muted">
                                <i class="bi bi-envelope"></i> @cv.Mentor.Email
                            </h6>
                            <hr />
                            <p class="card-text">
                                <strong class="text-dark">Giới thiệu:</strong>
                                <span class="d-block text-secondary mt-1">@cv.Bio</span>
                            </p>
                            <p class="card-text">
                                <strong class="text-dark">Kinh nghiệm:</strong>
                                <span class="d-block text-secondary mt-1">@cv.ExperienceYears</span>
                            </p>
                            <div class="mt-3">
                                <strong class="text-dark d-block mb-2">Kỹ năng chuyên môn:</strong>
                                @if (cv.Skills != null && cv.Skills.Any())
                                {
                                    foreach (var skill in cv.Skills)
                                    {
                                        <span class="badge bg-info text-dark me-1 mb-1 p-2" title="@skill.Category?.Name">@skill.Name</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted fst-italic">Chưa có thông tin kỹ năng</span>
                                }
                            </div>
                        </div>
                        <div class="card-footer bg-white border-top-0 pb-4 pt-0">
                            <a asp-controller="Request" asp-action="Create" asp-route-mentorId="@cv.MentorId" class="btn btn-outline-primary w-100 fw-bold" style="border-radius: 8px;">
                                Gửi Yêu cầu hỗ trợ
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <h4 class="text-muted">Chưa có hồ sơ Mentor nào trên hệ thống.</h4>
            </div>
        }
    </div>
</div>

<style>
    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
</style>
