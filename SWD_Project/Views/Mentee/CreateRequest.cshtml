@using SWD_Project.Models.Entities
@model Request

@{
    ViewData["Title"] = "Create Request";
}

<div class="row mt-4">
    <div class="col-md-8 offset-md-2">
        <h2>Create Request</h2>
        <hr />
        <form asp-action="CreateRequest">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="mb-3">
                <label class="form-label fw-bold">Request Type</label>
                <div class="card p-3 bg-light">
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" name="RequestType" id="typeOpen" value="open" checked onchange="toggleMentorSelect()">
                        <label class="form-check-label fw-bold" for="typeOpen">
                            Open Request (Gửi cho tất cả Mentor)
                        </label>
                        <small class="d-block text-muted">Bất kỳ mentor nào cũng có thể nhận request này.</small>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="RequestType" id="typeDirect" value="direct" onchange="toggleMentorSelect()">
                        <label class="form-check-label fw-bold" for="typeDirect">
                            Direct Request (Gửi cho 1 Mentor cụ thể)
                        </label>
                        <small class="d-block text-muted">Chỉ mentor được chọn mới thấy request này.</small>
                    </div>
                </div>
            </div>

            <div class="mb-3" id="mentorSelectDiv" style="display: none;">
                <label asp-for="MentorId" class="form-label fw-bold">Select Mentor</label>
                <select asp-for="MentorId" class="form-select" asp-items="@(new SelectList(ViewBag.Mentors, "Id", "FullName"))">
                    <option value="">-- Choose a Mentor --</option>
                </select>
                <span asp-validation-for="MentorId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label fw-bold"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="Content" class="form-label fw-bold"></label>
                <textarea asp-for="Content" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Content" class="text-danger"></span>
            </div>
            
            <div class="mt-4">
                <input type="submit" value="Create" class="btn btn-primary px-4" />
                <a asp-action="ListRequests" class="btn btn-outline-secondary ms-2">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        function toggleMentorSelect() {
            var type = document.querySelector('input[name="RequestType"]:checked').value;
            var mentorDiv = document.getElementById('mentorSelectDiv');
            var mentorSelect = document.getElementById('MentorId');
            if (type === 'direct') {
                mentorDiv.style.display = 'block';
                mentorSelect.setAttribute('required', 'required');
            } else {
                mentorDiv.style.display = 'none';
                mentorSelect.removeAttribute('required');
                mentorSelect.value = '';
            }
        }
        document.addEventListener("DOMContentLoaded", function() {
            toggleMentorSelect();
        });
    </script>
}
