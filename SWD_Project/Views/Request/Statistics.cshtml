@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Statistics";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Request Statistics</h2>
        <a asp-action="Index" class="btn btn-outline-primary">Back to List</a>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-md-4 mb-3">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center d-flex flex-column justify-content-center">
                            @{
                                string statusStr = item.Status.ToString();
                                string bgColorInfo = statusStr == "Pending" ? "text-warning" 
                                                   : statusStr == "Accepted" ? "text-info" 
                                                   : statusStr == "Completed" ? "text-success" 
                                                   : "text-muted";
                            }
                            <h5 class="card-title text-uppercase text-muted fw-bold mb-3">@item.Status</h5>
                            <h1 class="display-3 fw-bold @bgColorInfo">@item.Count</h1>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5">
            <h4 class="alert-heading">No Statistics Available</h4>
            <p>There are currently no requests to display statistics for.</p>
        </div>
    }
</div>
