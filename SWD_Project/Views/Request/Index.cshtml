@using SWD_Project.Models.Entities
@using SWD_Project.Models.Enums
@model IEnumerable<Request>

@{
    ViewData["Title"] = "My Requests";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>My Requests</h2>
        <a asp-action="Create" class="btn btn-primary">Create New</a>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <table class="table table-striped table-hover mt-3 shadow-sm rounded">
        <thead class="table-dark">
            <tr>
                <th>Mentor</th>
                <th>@Html.DisplayNameFor(model => model.Title)</th>
                <th>@Html.DisplayNameFor(model => model.Content)</th>
                <th>@Html.DisplayNameFor(model => model.Status)</th>
                <th>@Html.DisplayNameFor(model => model.CreatedAt)</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-bold">
                        @(item.Mentor?.FullName ?? "All Mentors (Open)")
                    </td>
                    <td>@item.Title</td>
                    <td>@(item.Content?.Length > 50 ? item.Content.Substring(0, 50) + "..." : item.Content)</td>
                    <td>
                        @if (item.Status == RequestStatus.Pending)
                        {
                            <span class="badge bg-warning text-dark">Pending</span>
                        }
                        else if (item.Status == RequestStatus.Accepted)
                        {
                            <span class="badge bg-info text-dark">Accepted</span>
                        }
                        else if (item.Status == RequestStatus.Completed)
                        {
                            <span class="badge bg-success">Completed</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@item.Status</span>
                        }
                    </td>
                    <td>@item.CreatedAt.ToString("g")</td>
                    <td class="text-center">
                        @if (item.Status == RequestStatus.Pending)
                        {
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger ms-1">Delete</a>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-outline-secondary" disabled>Edit</button>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <a asp-action="Statistics" class="btn btn-outline-secondary mt-2">View Statistics</a>
</div>
